# Generated by Cargo
# will have compiled files and executables
/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# OS / editor noise
.DS_Store
.vscode/

# Rust / compiler-generated artifacts
*.s
*.o
*.i
*.out
*.exe
*.pdb

# Python cache artifacts from the bundled test harness
**/__pycache__/
*.py[cod]

# Local reference / automation helpers not intended for the main repo
nqcc2/
scripts/
.omx/
